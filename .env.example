# Google Sheets
GOOGLE_SHEET_ID=                    # from sheet URL: .../spreadsheets/d/<ID>/edit
GOOGLE_OAUTH_PORT=8080              # port for local OAuth redirect
# credentials.json and token.json are expected in the repo root (standard paths, not configurable)

# LinkedIn API
LINKEDIN_CLIENT_ID=                 # from LinkedIn developer app Auth tab
LINKEDIN_CLIENT_SECRET=             # from LinkedIn developer app Auth tab
LINKEDIN_ACCESS_TOKEN=              # set automatically by linkedin_auth.py
LINKEDIN_PERSON_URN=                # set automatically by linkedin_auth.py

# Claude API (for draft generation)
CLAUDE_API_KEY=                     # from console.anthropic.com
